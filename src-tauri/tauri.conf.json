{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "carrotnotes",
  "version": "0.1.0",
  "identifier": "com.shakerbr.carrotnotes",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": "npm run build:vendor",
    "beforeBuildCommand": "npm run build:vendor"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CarrotNotes",
        "width": 460,
        "height": 600,
        "minWidth": 460,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
