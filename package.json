{
  "name": "carrotnotes",
  "version": "0.1.0",
  "description": "Minimalist, high-performance sticky notes application",
  "scripts": {
    "tauri": "tauri",
    "build:vendor": "node scripts/build-vendor.mjs",
    "dev": "npm run build:vendor && env -u WAYLAND_DISPLAY GDK_BACKEND=x11 tauri dev",
    "build": "npm run build:vendor && env -u WAYLAND_DISPLAY GDK_BACKEND=x11 tauri build",
    "postinstall": "npm run build:vendor"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-bullet-list": "^3.27.1",
    "@tiptap/extension-ordered-list": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/markdown": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "esbuild": "^0.25.5"
  }
}
